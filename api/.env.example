# This file is an example of environment variables for the Scan Card API. It contains configuration settings that are necessary for the API to function properly.
# You should create a copy of this file named `.env` and fill in the appropriate values for your environment.

# Port on which the API server will run
PORT=3000

# MySQL database settings
DB_HOST=mysql-scancard
DB_PORT=3306
DB_USER=app_user
DB_PASS=app_pass
DB_NAME=db_app

# Redis settings for caching and session management
REDIS_HOST=redis-scancard
REDIS_PORT=6379
REDIS_PASS=redis_pass

# JWT settings for authentication
JWT_SECRET=secret_key_for_jwt
JWT_EXPIRES_IN=2h

# Directory for file uploads
UPLOAD_DIR=/uploads

# OpenAI API key for AI features
OPENAI_API_KEY=your_openai_api_key_here

# Mail settings for sending emails
DEVELOPER_EMAIL=dev@example.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# RabbitMQ settings for worker statement AI
RABBITMQ_STATEMENT_AI_MAX_RETRIES=3
RABBITMQ_STATEMENT_AI_RETRY_DELAY=5000

# Rate limit for POST /api/cards/:cardId/statements (per user)
STATEMENT_RATE_LIMIT_MAX=5
STATEMENT_RATE_LIMIT_TTL=3600