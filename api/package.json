{
  "name": "tsexp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --runInBand",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/infra/database/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create -d src/infra/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/infra/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/infra/database/data-source.ts",
    "worker:statement-processor": "ts-node-dev --respawn --transpile-only src/workers/statement-processor.worker.ts",
    "worker:dlq": "ts-node-dev --respawn --transpile-only src/workers/dlq.worker.ts"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.16.0",
    "openai": "^6.34.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.0.8",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.9.3"
  }
}
